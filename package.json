{
  "name": "hm-immersive-block",
  "version": "1.0.0",
  "private": true,
  "description": "HM Immersive Block — full-viewport pinned-background scrolling slides powered by GSAP.",
  "author": "Human Made",
  "scripts": {
    "build": "wp-scripts build && npm run copy-vendor",
    "copy-vendor": "mkdir -p build/vendor && cp node_modules/gsap/dist/gsap.min.js node_modules/gsap/dist/ScrollTrigger.min.js build/vendor/",
    "start": "npm run copy-vendor && wp-scripts start"
  },
  "dependencies": {
    "gsap": "^3.12.2"
  },
  "devDependencies": {
    "@humanmade/block-editor-components": "^0.11.0",
    "@wordpress/scripts": "^32.3.0",
    "classnames": "^2.3.2"
  }
}
